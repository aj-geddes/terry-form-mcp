{{- if or .Values.github.enabled .Values.terraformCloud.enabled }}
apiVersion: v1
kind: Secret
metadata:
  name: {{ include "terry-form-mcp.fullname" . }}-secrets
  labels:
    {{- include "terry-form-mcp.labels" . | nindent 4 }}
type: Opaque
stringData:
  {{- if .Values.github.enabled }}
  # GitHub App secrets - these should be provided via external secret management
  github-app-id: {{ .Values.github.appId | quote }}
  # Private key and webhook secret should be created separately
  {{- end }}
  
  {{- if .Values.terraformCloud.enabled }}
  # Terraform Cloud secrets - these should be provided via external secret management
  # Token should be created separately
  {{- end }}
---
{{- if .Values.github.enabled }}
{{- if .Values.github.privateKeySecretName }}
# Reference to existing secret for GitHub App private key
apiVersion: v1
kind: Secret
metadata:
  name: {{ .Values.github.privateKeySecretName }}
  labels:
    {{- include "terry-form-mcp.labels" . | nindent 4 }}
    app.kubernetes.io/component: github-app
type: Opaque
# data:
#   private-key: <base64-encoded-private-key>
{{- end }}
{{- if .Values.github.webhookSecretName }}
# Reference to existing secret for GitHub webhook
apiVersion: v1
kind: Secret
metadata:
  name: {{ .Values.github.webhookSecretName }}
  labels:
    {{- include "terry-form-mcp.labels" . | nindent 4 }}
    app.kubernetes.io/component: github-webhook
type: Opaque
# data:
#   webhook-secret: <base64-encoded-webhook-secret>
{{- end }}
{{- end }}
---
{{- if .Values.terraformCloud.enabled }}
{{- if .Values.terraformCloud.authentication.tokenSecretName }}
# Reference to existing secret for Terraform Cloud API token
apiVersion: v1
kind: Secret
metadata:
  name: {{ .Values.terraformCloud.authentication.tokenSecretName }}
  labels:
    {{- include "terry-form-mcp.labels" . | nindent 4 }}
    app.kubernetes.io/component: terraform-cloud
type: Opaque
# data:
#   token: <base64-encoded-api-token>
{{- end }}
{{- end }}
{{- end }}